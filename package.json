{
  "name": "command-center",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "dev": "npm --workspace @app/shell run dev",
    "build": "npm --workspace @app/shell run build",
    "preview": "npm --workspace @app/shell run preview"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.45.0",
    "dompurify": "^3.4.11",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.1",
    "vite": "^5.4.10"
  }
}
